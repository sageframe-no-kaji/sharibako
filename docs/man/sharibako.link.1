.Sh NAME
.Nm "sharibako link"
.Nd "Link a scope key to an existing shared entry."
.Sh SYNOPSIS
.Nm
.Op Fl -vault Ar vault
.Op Fl -age-key Ar age-key
.Op Fl -json
.Op Fl -verbose
