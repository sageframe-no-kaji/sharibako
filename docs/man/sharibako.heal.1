.Nd "Report drift between the vault and materialized .env."
.Sh SYNOPSIS
.Nm
.Op Fl -vault Ar vault
.Op Fl -age-key Ar age-key
.Op Fl -json
.Op Fl -verbose
.Op Ar scope
.Op Fl -version
